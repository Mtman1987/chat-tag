
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the Astro Twitch Clash app.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "twitchUsername": {
          "type": "string",
          "description": "Twitch username of the user."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL of the user's avatar.",
          "format": "uri"
        },
        "score": {
          "type": "number",
          "description": "The user's current score from in-app games (Tag, Bingo)."
        },
        "communityPoints": {
          "type": "number",
          "description": "Points synced from an external community system."
        },
        "isIt": {
          "type": "boolean",
          "description": "Whether the user is currently 'It' in the chat tag game."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the user is currently active."
        },
        "tagImmunityUntil": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Timestamp until which the player is immune from being tagged."
        },
        "lastTaggedInStreamId": {
            "type": ["string", "null"],
            "description": "The ID of the stream where the player was last tagged."
        }
      },
      "required": [
        "id",
        "twitchUsername",
        "avatarUrl",
        "score",
        "isIt",
        "isActive"
      ]
    },
    "ChatTag": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatTag",
      "type": "object",
      "description": "Represents a chat tag event.",
      "properties": {
        "taggerId": {
          "type": "string",
          "description": "Reference to the User who tagged."
        },
        "taggedId": {
          "type": "string",
          "description": "Reference to the User who was tagged."
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of when the tag occurred.",
          "format": "date-time"
        },
        "streamerId": {
          "type": "string",
          "description": "Reference to the User whose stream the tag occurred in."
        }
      },
      "required": [
        "taggerId",
        "taggedId",
        "timestamp",
        "streamerId"
      ]
    },
    "GameSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GameSettings",
      "type": "object",
      "description": "Stores Discord/Twitch integration settings and game point values.",
      "properties": {
        "twitchClientId": {
          "type": "string"
        },
        "twitchClientSecret": {
          "type": "string"
        },
        "discordBotToken": {
          "type": "string"
        },
        "discordServerId": {
          "type": "string"
        },
        "twitchBotToken": {
          "type": "string"
        },
        "discordChannelId": {
          "type": "string"
        },
        "discordWebhookUrl": {
          "type": "string",
          "format": "uri"
        },
        "discordLeaderboardMessageId": {
          "type": "string"
        },
        "externalApiUrl": {
          "type": "string",
          "format": "uri"
        },
        "tagSuccessPoints": {
            "type": "number"
        },
        "tagPenaltyPoints": {
            "type": "number"
        },
        "bingoSquarePoints": {
            "type": "number"
        },
        "bingoWinPoints": {
            "type": "number"
        },
        "bingoCardsCompleted": {
          "type": "number",
          "description": "The total number of bingo cards completed by the community."
        }
      }
    },
    "BingoEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BingoEvent",
      "type": "object",
      "description": "Represents a bingo event.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to the User who got bingo."
        },
        "points": {
          "type": "number",
          "description": "Points awarded for the bingo."
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of when the bingo occurred.",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "points",
        "timestamp"
      ]
    },
    "BingoCardState": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "BingoCardState",
        "type": "object",
        "description": "Represents the shared state of the current bingo card.",
        "properties": {
          "phrases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "covered": {
            "type": "array",
            "items": { "type": ["string", "null"] }
          },
          "lastGenerated": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["phrases", "covered", "lastGenerated"]
    },
    "BingoSquareClaim": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BingoSquareClaim",
      "type": "object",
      "description": "Represents an event where a user claims a bingo square.",
      "properties": {
        "claimerId": {
          "type": "string",
          "description": "Reference to the User who claimed the square."
        },
        "streamerId": {
          "type": "string",
          "description": "Reference to the User whose stream the claim occurred in."
        },
        "phrase": {
          "type": "string",
          "description": "The phrase on the claimed square."
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of when the claim occurred.",
          "format": "date-time"
        }
      },
      "required": ["claimerId", "streamerId", "phrase", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "anonymous",
      "custom"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/chatTags/{chatTagId}": {
      "schema": {
        "$ref": "#/entities/ChatTag"
      },
      "description": "Stores chat tag events."
    },
    "/bingoEvents/{bingoEventId}": {
      "schema": {
        "$ref": "#/entities/BingoEvent"
      },
      "description": "Stores bingo events."
    },
    "/gameSettings/default": {
        "schema": {
            "$ref": "#/entities/GameSettings"
        },
        "description": "Singleton document to hold all game settings."
    },
    "/gameState/bingoCard": {
        "schema": {
            "$ref": "#/entities/BingoCardState"
        },
        "description": "Singleton document to hold the state of the shared bingo card."
    },
    "/bingoSquareClaims/{claimId}": {
      "schema": {
        "$ref": "#/entities/BingoSquareClaim"
      },
      "description": "Stores events for when a bingo square is claimed."
    }
  }
}
